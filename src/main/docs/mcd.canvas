{
	"nodes":[
		{"id":"121695b295bd389e","type":"text","text":"## EVENT\n- `id` `uuid` `pk`\n- `title` `varchar(50)` `not null`\n- `description` `text` `not null`\n- `start_date` `datetime` `not null`\n- `end_date` `datetime` `not null`\n- `location` `varchar(50)` `not null`\n-  `created_at` `timestamp` `default now()` `not null`","x":-100,"y":-720,"width":520,"height":271,"color":"#069171"},
		{"id":"e8113c9c28fefbe1","type":"text","text":"## CONTAIN","x":-480,"y":-609,"width":158,"height":50},
		{"id":"805cf399d01a20f0","type":"text","text":"## SESSION\n- `id` `uuid` `pk`\n- `title` `varchar(50)` `unique` `not null`\n- `description` `text` `not null`\n- `start_date` `datetime` `not null`\n- `end_date` `datetime` `not null`\n- `room` `varchar(50)` `not null`\n- `capacity` `int` `not null`\n-  `event_id` `uuid` `fk` `references` event(id)\n- `room_id` `uuid` `fk` `references` room(id)","x":-1240,"y":-751,"width":520,"height":334,"color":"#069171"},
		{"id":"4b7d350c75056011","type":"text","text":"## USER\n- `id` `uuid` `pk`\n- `first_name` `varchar(50)` `not null`\n- `last_name` `varchar(50)` `not null`\n-  `username` `unique`\n- `email` `varchar(50)` `unique` `not null`\n- `password` `varchar(100)`\n- `bio` `text`\n- `created_at` `timestamp` `default now()`\n- `profile_picture` `varchar(255)`\n-  `role` `enum (admin, speaker, participant)`","x":-1240,"y":288,"width":520,"height":360,"color":"#069171"},
		{"id":"f2c5fd3c1b68a5e0","type":"text","text":"## MANAGE\n\n- `id` `pk` `not null`\n-  `envent_id` `fk` `references` event(id)\n- `user_id` `fk` `references` user(id)","x":-100,"y":372,"width":520,"height":193},
		{"id":"92282d0c04b2c65a","type":"text","text":"## ASKS","x":-2358,"y":443,"width":116,"height":50},
